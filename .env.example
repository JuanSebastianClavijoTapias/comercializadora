# =============================================================================
#  FrutaSystem — Variables de entorno (plantilla)
#  Copia esto a .env y completa cada valor.
# =============================================================================

# ── Django ───────────────────────────────────────────────────────────────────
# Modo debug: True para desarrollo, False para producción.
DEBUG=False

# Clave secreta (50+ caracteres aleatorios). Genera una con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Dominios permitidos (separados por coma, sin espacios)
ALLOWED_HOSTS=mipagina.com,www.mipagina.com

# Orígenes confiables para CSRF vía HTTPS (separados por coma, sin espacios)
# Obligatorio en producción. ¡Incluye el https:// !
CSRF_TRUSTED_ORIGINS=https://mipagina.com,https://www.mipagina.com

# Path del panel de administración (sin / inicial ni final)
# Default: admin/
# Cambia esto por un nombre difícil de adivinar, ej: panel-g3st10n/
ADMIN_URL=admin/

# Indica si Django está detrás de un proxy (Nginx/Caddy/Apache)
# Debe estar en True si usas HTTPS terminado en el proxy.
BEHIND_PROXY=True

# Forzar redirección HTTP → HTTPS (Django lo hace si el proxy no)
SECURE_SSL_REDIRECT=False

# ── Base de Datos (PostgreSQL) ───────────────────────────────────────────────
DB_NAME=comercializadora
DB_USER=postgres
DB_PASSWORD=contraseña_segura
DB_HOST=localhost
DB_PORT=5432

# Mantener conexiones abiertas (segundos). En producción, 300 (5 min).
# En desarrollo déjalo vacío o 0.
CONN_MAX_AGE=300

# Usar SSL para la conexión a PostgreSQL (recomendado en producción)
DB_USE_SSL=False

# ── Anti brute-force (django-axes) ───────────────────────────────────────────
# Intentos fallidos antes de bloquear (por usuario+IP)
AXES_FAILURE_LIMIT=5

# Horas de bloqueo después de superar el límite
AXES_COOLOFF_TIME=1